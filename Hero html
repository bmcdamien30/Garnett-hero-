Here’s a paste‑ready index.html. Then upload your logo image to the same repo as logo.jpg (exact name), and it’ll display immediately.

1. Create index.html (paste this)
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>GarnettWork — Verify opportunity with certainty</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="description" content="GarnettWork is a deterministic truth engine. PASS / FAIL / REFUSE from sold comps with confidence and receipted audit trails.">
<style>
:root { --bg:#0b0f14; --fg:#eaeef3; --muted:#9fb0c3; --brand:#d9a441; --card:#111821; }
*{box-sizing:border-box}
html,body{margin:0;padding:0;background:var(--bg);color:var(--fg);font:16px/1.5 system-ui,-apple-system,Segoe UI,Roboto}
.wrap{min-height:100svh;display:grid;place-items:center;padding:28px}
.hero{max-width:980px;width:100%;display:grid;grid-template-columns:1fr 1fr;gap:28px;align-items:center}
@media(max-width:900px){.hero{grid-template-columns:1fr;gap:20px}}
.panel{background:var(--card);border:1px solid #1c2733;border-radius:16px;padding:22px}
.logo{display:flex;align-items:center;justify-content:center;background:#0f1620;border:1px solid #1c2733;border-radius:16px;padding:16px}
.logo img{max-width:100%;height:auto;border-radius:12px}
h1{font-size:42px;line-height:1.05;margin:0 0 12px}
p.sub{color:var(--muted);font-size:18px;margin:0 0 20px}
.cta{display:flex;gap:12px;flex-wrap:wrap;margin:8px 0 22px}
.btn{appearance:none;border:0;border-radius:10px;padding:12px 18px;font-weight:600;cursor:pointer}
.btn-primary{background:var(--brand);color:#121212}
.btn-secondary{background:#192230;color:var(--fg);border:1px solid #223040}
.trust{display:flex;gap:14px;flex-wrap:wrap;color:var(--muted);font-size:14px}
.input{display:flex;gap:10px;margin-top:10px}
.input input{flex:1;min-width:0;padding:12px;border-radius:10px;border:1px solid #233041;background:#0e141c;color:var(--fg)}
.signal{display:flex;align-items:center;gap:10px;margin-top:12px}
.badge{font-size:12px;padding:4px 8px;border-radius:999px;background:#132018;border:1px solid #22452f;color:#78d08c}
.muted{color:var(--muted);font-size:13px}
footer{margin-top:18px;color:var(--muted);font-size:12px;text-align:center}
</style>
</head>
<body>
<div class="wrap">
<section class="hero">
<div class="logo panel">
<!-- Upload your image as logo.jpg in the repo root -->
<img src="./logo.jpg" alt="GarnettWork logo">
</div>
<div class="panel">
<h1>Verify opportunity with certainty</h1>
<p class="sub">GarnettWork prices reality from sold comps—not vibes. Get a PASS / FAIL / REFUSE verdict with confidence and a receipted audit trail you can replay and prove.</p>
<div class="cta">
<button class="btn btn-primary" onclick="document.getElementById('url').focus()">Verify a listing</button>
<button class="btn btn-secondary" onclick="document.getElementById('how').scrollIntoView({behavior:'smooth'})">See how it works</button>
</div>

<div class="muted">Try it</div>
<div class="input">
<input id="url" placeholder="Paste an eBay listing URL or item ID">
<button class="btn btn-primary" onclick="verify()">Verify</button>
</div>
<div id="result" class="signal" style="display:none"></div>

<div id="how" class="trust" style="margin-top:16px">
<div>• Sold comps (cleaned & windowed)</div>
<div>• PASS / FAIL / REFUSE + confidence</div>
<div>• Replayable receipts</div>
</div>
</div>
</section>
</div>

<footer>Deterministic market truth • GarnettWork</footer>

<script>
async function verify(){
const el = document.getElementById('result');
const url = document.getElementById('url').value.trim();
if(!url){ el.style.display='block'; el.innerHTML='<span class="badge" 
style="background:#201313;border-color:#3e2424;color:#e28b8b">REFUSE</span> Paste a URL or item ID'; return; }
el.style.display='block'; el.innerHTML='<span class="muted">Checking…</span>';
try{
// Adjust buyPrice/condition as needed or add inputs
const resp = await fetch('/teaser', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ listingUrl:url, buyPrice: 100, condition:'Used' }) });
const data = await resp.json();
if(data?.ok){
const verdict = data.verdict  'PASS';
const conf = data.confidence  'MED';
const mp = data.marketPrice ? $${data.marketPrice} : '—';
const margin = Number.isFinite(data.marginPct) ? ${data.marginPct}% : '—';
el.innerHTML = <span class=\"badge\">${verdict} • ${conf}</span> Market: ${mp} • Margin: ${margin};
} else {
const reason = (data?.reason || 'REFUSE').toUpperCase();
el.innerHTML = <span class=\"badge\" style=\"background:#201313;border-color:#3e2424;color:#e28b8b\">${reason}</span> ${data?.error||'Unable to verify'};
}
} catch(e){
el.innerHTML = <span class=\"badge\" style=\"background:#201313;border-color:#3e2424;color:#e28b8b\">ERROR</span> ${e?.message||e};
}
}
</script>
</body>
</html>

